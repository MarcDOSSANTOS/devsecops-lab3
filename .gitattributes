# Git attributes for consistent line endings across platforms
# https://help.github.com/articles/dealing-with-line-endings/

# Auto-detect binary files and normalize line endings to LF
* text=auto

# Source code
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Executable files
*.sh eol=lf
*.bash eol=lf

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Images and binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.zip binary
*.gz binary
*.tar binary

# Node
package.json merge=union
package-lock.json merge=union
