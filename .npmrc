# NPM Configuration for Security

# Require verification for packages
audit=true
audit-level=moderate

# Prevent installing optional dependencies that may have vulnerabilities
no-optional=false

# Ensure package integrity
strict-ssl=true

# Use exact versions in production
save-exact=false

# Enable npm fund warnings
fund=true

# Prevent accidental publication
private=false

# Registry configuration
registry=https://registry.npmjs.org/

# Require valid license
engine-strict=false
